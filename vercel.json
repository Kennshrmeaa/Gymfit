{
  "version": 2,
  "buildCommand": "echo 'No build required'",
  "outputDirectory": "Code for Techno/Gym Techno/gymfit-ph",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/(?!api|.*\\.).*",
      "destination": "/index.html"
    }
  ]
}
